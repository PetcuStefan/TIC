const express = require("express");
const router = express.Router();
const { db } = require("../firebase");
const { authenticateToken, requireAdmin } = require("../auth");
const categories = require("../categories.js");

// GET ALL PRODUCTS
router.get("/", async (req, res) => {
  try {
    const snapshot = await db.collection("products").get();

    const products = snapshot.docs.map(doc => {
      const data = doc.data()

      const discountedPrice = data.discount
        ? data.price - (data.price * data.discount) / 100
        : data.price

      return {
        id: doc.id,
        ...data,
        discountedPrice
      }
    })

    res.json(products)

  } catch (err) {
    console.error(err)
    res.status(500).send("Error fetching products")
  }
})


// GET PRODUCTS BY CATEGORY
router.get("/category/:category", async (req, res) => {
  try {
    const snapshot = await db.collection("products")
      .where("category", "==", req.params.category)
      .get()

    const products = snapshot.docs.map(doc => ({
      id: doc.id,
      ...doc.data()
    }))

    res.json(products)

  } catch (err) {
    console.error(err)
    res.status(500).send("Error fetching category products")
  }
})


// GET PRODUCT BY ID
router.get("/:id", async (req, res) => {
  try {
    const doc = await db.collection("products").doc(req.params.id).get()

    if (!doc.exists) {
      return res.status(404).send("Product not found")
    }

    const product = doc.data()

    const discountedPrice = product.discount
      ? product.price - (product.price * product.discount) / 100
      : product.price

    res.json({
      id: doc.id,
      ...product,
      discountedPrice
    })

  } catch (err) {
    console.error(err)
    res.status(500).send("Error fetching product")
  }
})


// ADD PRODUCT (ADMIN)
router.post("/", authenticateToken, requireAdmin, async (req, res) => {
  const {
    name,
    price,
    category,
    description,
    image,
    stock,
    discount,
    socket,
    ramType,
    tdp,
    wattage
  } = req.body;

  if (!categories.includes(category)) {
    return res.status(400).send(`Invalid category. Must be one of: ${categories.join(", ")}`);
  }

  const product = {
    name,
    price,
    category,
    description: description || "",
    image: image || "",
    stock: stock || 0,
    discount: discount || 0,
    createdAt: new Date()
  };

  // ✅ Add fields ONLY if they exist
  if (socket) product.socket = socket;
  if (ramType) product.ramType = ramType;
  if (tdp) product.tdp = tdp;
  if (wattage) product.wattage = wattage;

  const docRef = await db.collection("products").add(product);
  res.json({ id: docRef.id, message: "Product added successfully" });
});

// UPDATE PRODUCT (ADMIN)
router.put("/:id", authenticateToken, requireAdmin, async (req, res) => {
  try {
    const productId = req.params.id;
    const data = req.body;

    if (data.stock !== undefined && data.stock < 0) {
      return res.status(400).send("Stock cannot be negative");
    }

    if (data.tdp !== undefined && data.tdp < 0) {
      return res.status(400).send("TDP cannot be negative");
    }

    if (data.wattage !== undefined && data.wattage < 0) {
      return res.status(400).send("Wattage cannot be negative");
    }

    await db.collection("products").doc(productId).update(data);

    res.send("Product updated successfully");

  } catch (err) {
    console.error(err);
    res.status(500).send("Error updating product");
  }
});


// DELETE PRODUCT (ADMIN)
router.delete("/:id", authenticateToken, requireAdmin, async (req, res) => {
  try {
    const productId = req.params.id

    await db.collection("products").doc(productId).delete()

    res.send("Product deleted successfully")

  } catch (err) {
    console.error(err)
    res.status(500).send("Error deleting product")
  }
})

router.get("/category/:category", async (req, res) => {
  try {
    const snapshot = await db.collection("products")
      .where("category", "==", req.params.category)
      .get()

    const products = snapshot.docs.map(doc => {
      const data = doc.data()
      const discountedPrice = data.discount
        ? data.price - (data.price * data.discount) / 100
        : data.price
      return { id: doc.id, ...data, discountedPrice }
    })

    res.json(products)
  } catch (err) {
    console.error(err)
    res.status(500).send("Error fetching category products")
  }
})

module.exports = router